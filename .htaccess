# =====================================
# SAFEPASS SECURITY
# =====================================

Options -Indexes

# =====================================
# ENABLE REWRITE
# =====================================

RewriteEngine On

# =====================================
# BLOCK IMPORTANT FOLDERS
# =====================================

RewriteRule ^config/ - [F,L]
RewriteRule ^database/ - [F,L]
RewriteRule ^vendor/ - [F,L]

# =====================================
# BLOCK SENSITIVE FILES
# =====================================

<FilesMatch "^(\.env|composer\.json|composer\.lock)$">

    Require all denied

</FilesMatch>

# =====================================
# SECURITY HEADERS
# =====================================

<IfModule mod_headers.c>

Header always set X-Frame-Options "DENY"

Header always set X-Content-Type-Options "nosniff"

Header always set Referrer-Policy "no-referrer"

Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.pwnedpasswords.com; object-src 'none';"

</IfModule>